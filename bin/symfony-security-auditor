declare(strict_types=1);

use VinceAmstoutz\SymfonySecurityAuditor\Standalone\StandaloneApplicationFactory;

(static function (): void {
    foreach ([__DIR__.'/../vendor/autoload.php', __DIR__.'/../../../autoload.php'] as $autoload) {
        if (is_file($autoload)) {
            require $autoload;

            return;
        }
    }

    fwrite(\STDERR, 'Composer autoloader not found. Run "composer install".'.\PHP_EOL);

    exit(1);
})();

$environment = getenv();

$bridgeAutoloadFile = StandaloneApplicationFactory::bridgeAutoloadFile($environment);
if (is_file($bridgeAutoloadFile)) {
    require_once $bridgeAutoloadFile;
}

exit(StandaloneApplicationFactory::fromEnvironment($environment)->create()->run());
