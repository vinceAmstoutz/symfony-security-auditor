{
    "main": "bin/symfony-security-auditor",
    "output": "symfony-security-auditor.phar",
    "directories": ["config", "src"],
    "finder": [
        {
            "notName": ["*.md", "*.dist", "Makefile", "composer.json", "composer.lock"],
            "exclude": ["doc", "docs", "test", "tests", "Tests", "Test", "examples", "example"],
            "in": "vendor"
        }
    ],
    "compactors": ["KevinGH\\Box\\Compactor\\Php"],
    "compression": "GZ"
}
